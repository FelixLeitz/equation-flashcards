{
  "name": "equation-flashcards",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.14.0"
  },
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently -n SERVER,CLIENT -c blue,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "build": "npm run build -w client",
    "test": "npm test -w server && npm test -w client",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "start": "npm start -w server"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FelixLeitz/equation-flashcards.git"
  },
  "keywords": [],
  "author": "Felix Leitz",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/FelixLeitz/equation-flashcards/issues"
  },
  "homepage": "https://github.com/FelixLeitz/equation-flashcards#readme",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4"
  }
}
