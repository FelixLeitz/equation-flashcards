# Client environment configuration
# Copy to .env and fill in real values: cp .env.example .env
#
# NOTE: Only variables prefixed with VITE_ are exposed to the browser.
# Never put secrets here — anything in the client bundle is public.

# API base URL.
# Leave EMPTY in development (the Vite dev proxy forwards /api to the backend).
# Set to the deployed backend URL in production, e.g. https://api.yourapp.com
VITE_API_BASE_URL=

# Sentry error tracking (optional; leave empty to disable in development)
VITE_SENTRY_DSN=
