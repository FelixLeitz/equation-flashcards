# Server environment configuration
# Copy to .env and fill in real values: cp .env.example .env

NODE_ENV=development
PORT=3000

# Frontend origin for CORS (Vite dev default)
FRONTEND_ORIGIN=http://localhost:5173

# Database — REQUIRED (Atlas connection string or local instance)
# Local:  mongodb://localhost:27017/equation-flashcards
# Atlas:  mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net/equation-flashcards
MONGODB_URI=mongodb://localhost:27017/equation-flashcards

# Auth — required once the auth layer is added
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# JWT_SECRET=

# Error tracking (optional in development)
# SENTRY_DSN=
